# 複製此檔為 .env.local 並填入你的 Supabase 專案資訊。
# 若不填，App 會自動使用內建的本地假資料（seed data）運行，
# 所有功能（含外送員移動模擬）仍可正常體驗，只是不寫入資料庫。

# Supabase 專案 URL，例如 https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key（可公開，給瀏覽器用）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key（機密！只在 Server Action 使用，禁止暴露前端）
SUPABASE_SERVICE_ROLE_KEY=
